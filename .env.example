# ==========================
# InferFlow — Environment Configuration
# ==========================
# Copy this file to .env and fill in the values.
# Do NOT commit .env to version control.

# --------------------------
# Application
# --------------------------
APP_ENV=development
LOG_LEVEL=INFO

# --------------------------
# PostgreSQL
# --------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=inferflow
POSTGRES_PASSWORD=inferflow_dev_password
POSTGRES_DB=inferflow

# Convenience DSN (used by services)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --------------------------
# Redis
# --------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --------------------------
# Chat Service
# --------------------------
CHAT_SERVICE_HOST=0.0.0.0
CHAT_SERVICE_PORT=8000

# --------------------------
# Monitoring Service
# --------------------------
MONITORING_SERVICE_HOST=0.0.0.0
MONITORING_SERVICE_PORT=8001

# --------------------------
# LLM Provider (future)
# --------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4

# --------------------------
# Frontend
# --------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8001
